    <script>
        // ==================== STATE ====================
        const state = {
            mode: 'image',
            messages: [],
            generatedImages: [],
            uploadedFiles: [],
            isGenerating: false,
            currentPrompt: '',
            autoEnhance: true,
            settings: {
                stylePreset: 'photorealistic',
                quality: 2,
                aspectRatio: '16:9',
                creativity: 3
            }
        };

        const templates = [
            { id: 1, name: 'Portrait Photography', icon: 'fa-user', color: 'violet', prompt: 'Professional portrait photography, beautiful bokeh background, soft natural lighting, shallow depth of field, emotional expression, high-end camera quality' },
            { id: 2, name: 'Cinematic Scene', icon: 'fa-film', color: 'amber', prompt: 'Cinematic movie scene, dramatic lighting, anamorphic lens flare, color graded, 35mm film look, directed by Denis Villeneuve, wide establishing shot' },
            { id: 3, name: 'Nature Landscape', icon: 'fa-mountain', color: 'emerald', prompt: 'Breathtaking nature landscape, golden hour, dramatic sky, pristine wilderness, National Geographic quality, ultra wide angle' },
            { id: 4, name: 'Product Shot', icon: 'fa-box', color: 'cyan', prompt: 'Professional product photography, studio lighting, clean white background, commercial quality, luxury brand aesthetic, sharp details' },
            { id: 5, name: 'Architecture', icon: 'fa-building', color: 'blue', prompt: 'Architectural photography, modern building design, symmetrical composition, golden ratio, professional wide-angle lens, dramatic perspective' },
            { id: 6, name: 'Fantasy Art', icon: 'fa-dragon', color: 'pink', prompt: 'Epic fantasy art, magical realm, ethereal lighting, detailed digital painting, concept art quality, mystical atmosphere' },
            { id: 7, name: 'Street Photo', icon: 'fa-street-view', color: 'orange', prompt: 'Street photography, urban life, candid moment, natural light, documentary style, black and white film grain, decisive moment' },
            { id: 8, name: 'Food Photography', icon: 'fa-utensils', color: 'red', prompt: 'Professional food photography, appetizing presentation, natural window light, shallow depth of field, editorial quality, styled plating' },
            { id: 9, name: 'Anime Style', icon: 'fa-star', color: 'purple', prompt: 'Beautiful anime illustration, vibrant colors, clean line art, Studio Ghibli inspired, detailed background, emotional atmosphere' }
        ];

        // ==================== INIT ====================
        function init() {
            renderTemplates();
            addWelcomeMessage();
            document.getElementById('currentUrl').textContent = window.location.href;
            
            // Drag & drop
            const body = document.body;
            body.addEventListener('dragover', (e) => { e.preventDefault(); });
            body.addEventListener('drop', (e) => {
                e.preventDefault();
                if (e.dataTransfer.files.length) {
                    document.getElementById('fileInput').files = e.dataTransfer.files;
                    handleFileUpload({ target: { files: e.dataTransfer.files } });
                }
            });
        }

        function addWelcomeMessage() {
            const hour = new Date().getHours();
            const greeting = hour < 12 ? 'Good morning' : hour < 18 ? 'Good afternoon' : 'Good evening';
            
            addAgentMessage(`${greeting}! 👋 I'm your <b>CreativeAI Agent</b>. I can help you create stunning images and videos!<br><br>
                🎨 <b>Just describe</b> what you want to create<br>
                ✏️ <b>Upload photos/videos</b> as references<br>
                🔧 <b>Ask me to modify</b> any creation<br>
                📋 <b>Use templates</b> for quick starts<br><br>
                Try saying: <i>"Create a beautiful sunset over the ocean"</i>
            `);
        }

        function renderTemplates() {
            const grid = document.getElementById('templatesGrid');
            const colorMap = {
                violet: 'from-violet-500/20 to-violet-600/5 border-violet-500/20',
                amber: 'from-amber-500/20 to-amber-600/5 border-amber-500/20',
                emerald: 'from-emerald-500/20 to-emerald-600/5 border-emerald-500/20',
                cyan: 'from-cyan-500/20 to-cyan-600/5 border-cyan-500/20',
                blue: 'from-blue-500/20 to-blue-600/5 border-blue-500/20',
                pink: 'from-pink-500/20 to-pink-600/5 border-pink-500/20',
                orange: 'from-orange-500/20 to-orange-600/5 border-orange-500/20',
                red: 'from-red-500/20 to-red-600/5 border-red-500/20',
                purple: 'from-purple-500/20 to-purple-600/5 border-purple-500/20'
            };
            
            grid.innerHTML = templates.map(t => `
                <div class="template-card bg-gradient-to-br ${colorMap[t.color]} border rounded-xl p-4 cursor-pointer" onclick="useTemplate(${t.id})">
                    <div class="flex items-center gap-3 mb-3">
                        <div class="w-10 h-10 rounded-lg bg-white/10 flex items-center justify-center">
                            <i class="fas ${t.icon} text-${t.color}-400"></i>
                        </div>
                        <h4 class="font-heading font-medium text-sm">${t.name}</h4>
                    </div>
                    <p class="text-xs text-gray-400 line-clamp-2">${t.prompt.substring(0, 80)}...</p>
                    <div class="mt-3 text-xs text-violet-400 font-medium">Use Template →</div>
                </div>
            `).join('');
        }

        // ==================== CHAT FUNCTIONS ====================
        function addAgentMessage(text, imageUrl = null) {
            const container = document.getElementById('chatContainer');
            const msgDiv = document.createElement('div');
            msgDiv.className = 'flex gap-3 mb-4 message-agent rounded-xl p-3 md:p-4 generated-image';
            
            let imageHtml = '';
            if (imageUrl) {
                imageHtml = `
                    <div class="mt-3 relative group">
                        <img src="${imageUrl}" class="w-full rounded-lg cursor-pointer max-h-80 object-cover" onclick="openPreview('${imageUrl}')" loading="lazy">
                        <div class="absolute bottom-2 right-2 flex gap-1 opacity-0 group-hover:opacity-100 transition">
                            <button onclick="event.stopPropagation(); downloadFromUrl('${imageUrl}')" class="w-8 h-8 rounded-lg bg-black/60 flex items-center justify-center text-white text-xs hover:bg-black/80">
                                <i class="fas fa-download"></i>
                            </button>
                            <button onclick="event.stopPropagation(); regenerateLast()" class="w-8 h-8 rounded-lg bg-black/60 flex items-center justify-center text-white text-xs hover:bg-black/80">
                                <i class="fas fa-redo"></i>
                            </button>
                        </div>
                    </div>
                `;
            }
            
            msgDiv.innerHTML = `
                <div class="w-7 h-7 md:w-8 md:h-8 rounded-full bg-gradient-to-br from-violet-500 to-amber-500 flex items-center justify-center flex-shrink-0 mt-1">
                    <i class="fas fa-robot text-xs md:text-sm"></i>
                </div>
                <div class="flex-1 min-w-0">
                    <div class="text-xs text-violet-400 mb-1 font-medium">CreativeAI</div>
                    <div class="text-sm text-gray-200 leading-relaxed">${text}</div>
                    ${imageHtml}
                </div>
            `;
            
            container.appendChild(msgDiv);
            container.scrollTop = container.scrollHeight;
        }

        function addUserMessage(text) {
            const container = document.getElementById('chatContainer');
            const msgDiv = document.createElement('div');
            msgDiv.className = 'flex justify-end mb-4 generated-image';
            msgDiv.innerHTML = `
                <div class="message-user rounded-xl px-4 py-3 max-w-[85%] lg:max-w-[70%]">
                    <div class="text-sm">${text}</div>
                </div>
            `;
            container.appendChild(msgDiv);
            container.scrollTop = container.scrollHeight;
        }

        function showTyping() {
            document.getElementById('typingIndicator').classList.remove('hidden');
            document.getElementById('chatContainer').scrollTop = document.getElementById('chatContainer').scrollHeight;
        }

        function hideTyping() {
            document.getElementById('typingIndicator').classList.add('hidden');
        }

        // ==================== SEND MESSAGE ====================
        async function sendMessage() {
            const input = document.getElementById('userInput');
            const text = input.value.trim();
            if (!text || state.isGenerating) return;
            
            input.value = '';
            addUserMessage(text);
            
            const intent = detectIntent(text);
            
            switch(intent) {
                case 'generate':
                    await generateImage(text);
                    break;
                case 'modify':
                    await modifyImage(text);
                    break;
                case 'help':
                    showHelp();
                    break;
                case 'settings':
                    updateSettingsFromChat(text);
                    break;
                default:
                    await generateImage(text);
            }
        }

        function detectIntent(message) {
            const lowerMsg = message.toLowerCase();
            if (lowerMsg.includes('create') || lowerMsg.includes('generate') || lowerMsg.includes('make') || lowerMsg.includes('draw')) return 'generate';
            if (lowerMsg.includes('modify') || lowerMsg.includes('change') || lowerMsg.includes('update') || lowerMsg.includes('edit') || lowerMsg.includes('add') || lowerMsg.includes('remove')) return 'modify';
            if (lowerMsg.includes('help') || lowerMsg.includes('how') || lowerMsg.includes('what can')) return 'help';
            if (lowerMsg.includes('setting') || lowerMsg.includes('style') || lowerMsg.includes('quality')) return 'settings';
            return 'generate';
        }

        // ==================== IMAGE GENERATION ====================
        async function generateImage(prompt) {
            state.isGenerating = true;
            showTyping();
            
            const enhancedPrompt = enhancePrompt(prompt);
            
            addAgentMessage(`🎨 Creating your image...\n\n<strong>Prompt:</strong> "${enhancedPrompt}"\n\nThis may take 10-30 seconds...`);
            
            const seed = Math.floor(Math.random() * 1000000);
            const width = state.settings.aspectRatio === '1:1' ? 1024 : state.settings.aspectRatio === '9:16' ? 768 : 1280;
            const height = state.settings.aspectRatio === '1:1' ? 1024 : state.settings.aspectRatio === '9:16' ? 1280 : 768;
            
            const imageUrl = `https://image.pollinations.ai/prompt/${encodeURIComponent(enhancedPrompt)}?width=${width}&height=${height}&seed=${seed}&nologo=true`;
            
            // Pre-load the image
            try {
                await new Promise((resolve, reject) => {
                    const img = new Image();
                    img.onload = resolve;
                    img.onerror = reject;
                    img.src = imageUrl;
                    setTimeout(() => resolve(), 30000); // timeout fallback
                });
            } catch(e) {}
            
            hideTyping();
            state.isGenerating = false;
            
            addToGallery(imageUrl);
            state.currentPrompt = enhancedPrompt;
            state.generatedImages.push({ url: imageUrl, prompt: enhancedPrompt });
            
            addAgentMessage(`✅ Here's your generated image! I used <b>${state.settings.stylePreset}</b> style with <b>${getQualityText()}</b> quality.\n\nWant me to modify it? Just describe the changes you'd like!`, imageUrl);
        }

        function enhancePrompt(prompt) {
            if (!state.autoEnhance) return prompt;
            const styleEnhancements = {
                'photorealistic': 'Photorealistic, highly detailed, shot on professional camera, natural lighting, 8K resolution',
                'artistic': 'Artistic style, beautiful composition, creative interpretation, gallery quality',
                'anime': 'Anime art style, vibrant colors, clean lines, Studio Ghibli inspired',
                '3d': '3D rendered, octane render, highly detailed, studio lighting, CGI quality',
                'cinematic': 'Cinematic, movie scene, dramatic lighting, color graded, film look',
                'abstract': 'Abstract art, creative composition, bold colors, modern art style'
            };
            const enhancement = styleEnhancements[state.settings.stylePreset] || '';
            return `${prompt}, ${enhancement}`;
        }

        async function modifyImage(instruction) {
            const lastImage = state.generatedImages[state.generatedImages.length - 1];
            if (!lastImage) {
                return await generateImage(instruction);
            }
            
            state.isGenerating = true;
            showTyping();
            
            const modifiedPrompt = `${lastImage.prompt}, ${instruction}`;
            addAgentMessage(`🔧 Modifying with: "${instruction}"\n\nGenerating updated version...`);
            
            const seed = Math.floor(Math.random() * 1000000);
            const w = state.settings.aspectRatio === '1:1' ? 1024 : state.settings.aspectRatio === '9:16' ? 768 : 1280;
            const h = state.settings.aspectRatio === '1:1' ? 1024 : state.settings.aspectRatio === '9:16' ? 1280 : 768;
            const imageUrl = `https://image.pollinations.ai/prompt/${encodeURIComponent(modifiedPrompt)}?width=${w}&height=${h}&seed=${seed}&nologo=true`;
            
            try {
                await new Promise((resolve, reject) => {
                    const img = new Image();
                    img.onload = resolve;
                    img.onerror = reject;
                    img.src = imageUrl;
                    setTimeout(() => resolve(), 30000);
                });
            } catch(e) {}
            
            hideTyping();
            state.isGenerating = false;
            
            addToGallery(imageUrl);
            state.generatedImages.push({ url: imageUrl, prompt: modifiedPrompt });
            
            addAgentMessage(`✅ Modified image ready! What else would you like to change?`, imageUrl);
        }

        // ==================== HELP & SETTINGS ====================
        function showHelp() {
            addAgentMessage(`📚 <b>Here's how I can help you:</b><br><br>
                🎨 <b>Generate:</b> "Create a serene mountain landscape at sunset"<br>
                ✏️ <b>Modify:</b> "Make it more colorful" or "Add dramatic lighting"<br>
                📷 <b>Style:</b> "Change to anime style" or "Make it cinematic"<br>
                ⚙️ <b>Settings:</b> "Set quality to ultra" or "Aspect ratio 1:1"<br>
                📎 <b>Upload:</b> Attach reference images/videos via 📎 button<br>
                📋 <b>Templates:</b> Click Templates button for presets<br><br>
                💡 <b>Tip:</b> On mobile, tap the ☰ menu for settings & gallery!
            `);
        }

        function updateSettingsFromChat(message) {
            const lowerMsg = message.toLowerCase();
            if (lowerMsg.includes('high quality') || lowerMsg.includes('ultra') || lowerMsg.includes('best')) {
                state.settings.quality = 3;
                document.getElementById('quality').value = 3;
                updateQuality();
                addAgentMessage("✅ Quality set to <b>Ultra</b>!");
            } else if (lowerMsg.includes('anime')) {
                state.settings.stylePreset = 'anime';
                document.getElementById('stylePreset').value = 'anime';
                addAgentMessage("✅ Style changed to <b>Anime</b>!");
            } else if (lowerMsg.includes('photo') || lowerMsg.includes('realistic')) {
                state.settings.stylePreset = 'photorealistic';
                document.getElementById('stylePreset').value = 'photorealistic';
                addAgentMessage("✅ Style set to <b>Photorealistic</b>!");
            } else if (lowerMsg.includes('cinematic')) {
                state.settings.stylePreset = 'cinematic';
                document.getElementById('stylePreset').value = 'cinematic';
                addAgentMessage("✅ Style set to <b>Cinematic</b>!");
            } else {
                addAgentMessage("I can change: <b>style</b> (photorealistic, anime, cinematic, artistic, 3d, abstract), <b>quality</b> (standard, high, ultra), or <b>aspect ratio</b>. What would you like to change?");
            }
        }

        // ==================== QUICK ACTIONS ====================
        function quickAction(action) {
            const lastImage = state.generatedImages[state.generatedImages.length - 1];
            switch(action) {
                case 'enhance':
                    if (lastImage) modifyImage('enhanced details, better lighting, more vibrant colors, professional quality');
                    else addAgentMessage("Generate an image first, then I can enhance it!");
                    break;
                case 'upscale':
                    state.settings.quality = 3;
                    document.getElementById('quality').value = 3;
                    updateQuality();
                    addAgentMessage("🔧 Upscaling enabled! Next generation will be at maximum resolution.");
                    break;
                case 'variations':
                    if (lastImage) regenerateLast();
                    else addAgentMessage("Generate an image first, then I can create variations!");
                    break;
                case 'style':
                    addAgentMessage("🎨 Which style?\n\n• <b>Photorealistic</b>\n• <b>Artistic</b>\n• <b>Anime</b>\n• <b>3D Render</b>\n• <b>Cinematic</b>\n• <b>Abstract</b>\n\nJust tell me!");
                    break;
            }
        }

        // ==================== UTILITIES ====================
        function useTemplate(id) {
            const template = templates.find(t => t.id === id);
            if (template) {
                document.getElementById('userInput').value = template.prompt;
                closeTemplates();
                addAgentMessage(`📋 Template "${template.name}" loaded! Click <b>Send</b> to generate, or edit the prompt first.`);
            }
        }

        function regenerateLast() {
            const lastImage = state.generatedImages[state.generatedImages.length - 1];
            if (lastImage) generateImage(lastImage.prompt.split(', Photorealistic')[0].split(', Artistic')[0].split(', Anime')[0].split(', 3D')[0].split(', Cinematic')[0].split(', Abstract')[0]);
        }

        function addToGallery(imageUrl) {
            state.generatedImages.unshift({ url: imageUrl });
            updateGalleryDisplay();
        }

        function updateGalleryDisplay() {
            const gallery = document.getElementById('gallery');
            const images = state.generatedImages.slice(0, 4);
            let html = images.map(img => `
                <div class="aspect-square rounded-lg overflow-hidden cursor-pointer hover:ring-2 hover:ring-violet-500 transition" onclick="openPreview('${img.url}')">
                    <img src="${img.url}" class="w-full h-full object-cover" loading="lazy">
                </div>
            `).join('');
            for (let i = images.length; i < 4; i++) {
                html += `<div class="aspect-square rounded-lg bg-white/5 flex items-center justify-center text-gray-600"><i class="fas fa-image text-xl"></i></div>`;
            }
            gallery.innerHTML = html;
        }

        function clearGallery() {
            state.generatedImages = [];
            updateGalleryDisplay();
            addAgentMessage("🗑️ Gallery cleared!");
        }

        // ==================== MODALS ====================
        function openTemplates() { document.getElementById('templatesModal').classList.remove('hidden'); document.getElementById('templatesModal').classList.add('flex'); }
        function closeTemplates() { document.getElementById('templatesModal').classList.add('hidden'); document.getElementById('templatesModal').classList.remove('flex'); }
        function openSettings() { document.getElementById('settingsModal').classList.remove('hidden'); document.getElementById('settingsModal').classList.add('flex'); }
        function closeSettings() { document.getElementById('settingsModal').classList.add('hidden'); document.getElementById('settingsModal').classList.remove('flex'); }
        function openPreview(imageUrl) { document.getElementById('previewImage').src = imageUrl; document.getElementById('previewModal').classList.remove('hidden'); document.getElementById('previewModal').classList.add('flex'); }
        function closePreview() { document.getElementById('previewModal').classList.add('hidden'); document.getElementById('previewModal').classList.remove('flex'); }
        function openDeployGuide() { document.getElementById('deployModal').classList.remove('hidden'); document.getElementById('deployModal').classList.add('flex'); }
        function closeDeployGuide() { document.getElementById('deployModal').classList.add('hidden'); document.getElementById('deployModal').classList.remove('flex'); }

        // ==================== SIDEBAR (MOBILE) ====================
        function toggleSidebar() {
            const panel = document.getElementById('sidebarPanel');
            const overlay = document.getElementById('sidebarOverlay');
            if (panel.classList.contains('open')) {
                panel.classList.remove('open');
                overlay.classList.add('hidden');
            } else {
                panel.classList.add('open');
                overlay.classList.remove('hidden');
            }
        }

        // ==================== MODE & SETTINGS ====================
        function setMode(mode) {
            state.mode = mode;
            document.querySelectorAll('[id^="tab-"]').forEach(tab => { tab.classList.remove('tab-active'); tab.classList.add('bg-white/5'); });
            document.getElementById(`tab-${mode}`).classList.add('tab-active');
            document.getElementById(`tab-${mode}`).classList.remove('bg-white/5');
            
            const msgs = {
                'image': '🎨 Image Generation mode. Describe what you want!',
                'video': '🎬 Video mode. Note: Full video generation requires API integration. Currently showing animated previews.',
                'edit': '✏️ Edit mode. Upload an image or describe modifications.'
            };
            addAgentMessage(msgs[mode]);
        }

        function setAspectRatio(ratio) {
            state.settings.aspectRatio = ratio;
            document.querySelectorAll('.aspect-btn').forEach(btn => { btn.classList.remove('bg-violet-500/30'); btn.classList.add('bg-white/5'); });
            document.querySelector(`[data-ratio="${ratio}"]`).classList.add('bg-violet-500/30');
            document.querySelector(`[data-ratio="${ratio}"]`).classList.remove('bg-white/5');
        }

        function updateQuality() {
            state.settings.quality = parseInt(document.getElementById('quality').value);
            document.getElementById('qualityValue').textContent = getQualityText();
        }

        function getQualityText() { return ['Standard', 'High', 'Ultra'][state.settings.quality - 1]; }

        function updateCreativity() {
            state.settings.creativity = parseInt(document.getElementById('creativity').value);
            document.getElementById('creativityValue').textContent = ['Conservative', 'Careful', 'Balanced', 'Creative', 'Experimental'][state.settings.creativity - 1];
        }

        function toggleAutoEnhance() {
            state.autoEnhance = !state.autoEnhance;
            document.getElementById('autoEnhanceLabel').textContent = state.autoEnhance ? 'Enabled' : 'Disabled';
        }

        // ==================== FILE UPLOAD ====================
        function toggleUpload() { document.getElementById('uploadZone').classList.toggle('hidden'); }

        function handleFileUpload(event) {
            const files = event.target.files;
            const container = document.getElementById('uploadedFiles');
            for (let file of files) {
                const reader = new FileReader();
                reader.onload = (e) => {
                    state.uploadedFiles.push({ name: file.name, data: e.target.result });
                    const fileDiv = document.createElement('div');
                    fileDiv.className = 'relative group';
                    if (file.type.startsWith('image/')) {
                        fileDiv.innerHTML = `<img src="${e.target.result}" class="w-14 h-14 md:w-16 md:h-16 object-cover rounded-lg"><button onclick="removeFile('${file.name}')" class="absolute -top-1 -right-1 w-4 h-4 bg-red-500 rounded-full text-[10px] flex items-center justify-center">×</button>`;
                    } else {
                        fileDiv.innerHTML = `<div class="w-14 h-14 md:w-16 md:h-16 bg-white/10 rounded-lg flex items-center justify-center"><i class="fas fa-video text-violet-400 text-sm"></i></div><button onclick="removeFile('${file.name}')" class="absolute -top-1 -right-1 w-4 h-4 bg-red-500 rounded-full text-[10px] flex items-center justify-center">×</button>`;
                    }
                    container.appendChild(fileDiv);
                };
                reader.readAsDataURL(file);
            }
            addAgentMessage(`📎 ${files.length} file(s) uploaded! I'll use these as reference.`);
        }

        function removeFile(name) { state.uploadedFiles = state.uploadedFiles.filter(f => f.name !== name); }

        // ==================== DOWNLOAD ====================
        function downloadFromUrl(url) {
            const a = document.createElement('a');
            a.href = url;
            a.download = `creativeai-${Date.now()}.png`;
            a.target = '_blank';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        }

        function downloadImage() { downloadFromUrl(document.getElementById('previewImage').src); }

        function regenerateFromPreview() { closePreview(); regenerateLast(); }

        function editInChat() {
            closePreview();
            document.getElementById('userInput').focus();
            addAgentMessage("What changes would you like to make?");
        }

        // ==================== COPY FUNCTIONS ====================
        function copyCode(btn) {
            const code = btn.parentElement.textContent.replace('Copy', '').trim();
            navigator.clipboard.writeText(code).then(() => {
                btn.textContent = 'Copied!';
                setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
            });
        }

        function copyCurrentUrl() {
            navigator.clipboard.writeText(window.location.href).then(() => {
                const el = document.querySelector('#currentUrl');
                const original = el.textContent;
                el.textContent = '✓ Copied!';
                setTimeout(() => { el.textContent = original; }, 2000);
            });
        }

        // ==================== EVENT LISTENERS ====================
        document.getElementById('stylePreset').addEventListener('change', (e) => {
            state.settings.stylePreset = e.target.value;
            addAgentMessage(`🎨 Style changed to <b>${e.target.value}</b>.`);
        });

        document.querySelectorAll('[id$="Modal"]').forEach(modal => {
            modal.addEventListener('click', (e) => {
                if (e.target === modal) { modal.classList.add('hidden'); modal.classList.remove('flex'); }
            });
        });

        // Init
        init();
    </script>
</body>
</html>
